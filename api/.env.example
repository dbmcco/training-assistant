# Database
DATABASE_URL=postgresql+asyncpg://<user>@127.0.0.1:5432/assistant
DATABASE_URL_SYNC=postgresql://<user>@127.0.0.1:5432/assistant

# SQLAlchemy / DB pool tuning
DB_CONNECT_TIMEOUT_SECONDS=6
DB_COMMAND_TIMEOUT_SECONDS=20
DB_STATEMENT_TIMEOUT_MS=15000
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=1800

# LLM
ANTHROPIC_API_KEY=
COACH_MODEL=claude-sonnet-4-6

# CORS (JSON list)
CORS_ORIGINS=["http://localhost:4100","http://localhost:5173"]

# Garmin writeback bridge
GARMIN_WRITEBACK_ENABLED=false
GARMIN_WRITEBACK_REPO=
GARMIN_WRITEBACK_PYTHON=

# Garmin on-demand refresh bridge
GARMIN_REFRESH_ENABLED=false
GARMIN_REFRESH_REPO=
GARMIN_REFRESH_PYTHON=
GARMIN_REFRESH_TIMEOUT_SECONDS=90
GARMIN_REFRESH_MIN_INTERVAL_SECONDS=120
